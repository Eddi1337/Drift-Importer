[Unit]
Description=Drift-Import camera offload & upload manager
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/drift-import
EnvironmentFile=/opt/drift-import/.env
ExecStart=/opt/drift-import/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8080 --workers 1
Restart=on-failure
RestartSec=5
# Keep memory in check on a Pi Zero 2 W (512MB). Adjust if you see OOM kills.
MemoryMax=400M

[Install]
WantedBy=multi-user.target
