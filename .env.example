# Drift-Import configuration. Copy to .env and edit.

# Where the SQLite database, secret key, thumbnails and merged clips live.
DRIFT_DATA_DIR=./data
DRIFT_WORKING_DIR=./working          # where merged/derived clips are written
DRIFT_THUMBNAIL_DIR=./thumbnails

# Paths to scan for an attached DCIM camera. Comma-separated.
# On Raspberry Pi OS with auto-mount this is usually /media/<user>.
DRIFT_MOUNT_PATHS=/media,/mnt,/run/media,/Volumes

# Web server
DRIFT_HOST=0.0.0.0
DRIFT_PORT=8080

# Optional single-user auth. Leave password blank to disable login entirely.
DRIFT_AUTH_USERNAME=admin
DRIFT_AUTH_PASSWORD=

# Resource limits (tuned for a Pi Zero 2 W, 512MB RAM).
DRIFT_MAX_CONCURRENT_UPLOADS=1
DRIFT_MAX_CONCURRENT_FFMPEG=1
DRIFT_UPLOAD_CHUNK_BYTES=8388608     # 8 MiB streaming chunk

# ffmpeg / ffprobe binaries
DRIFT_FFMPEG=ffmpeg
DRIFT_FFPROBE=ffprobe

# Optional private key for the rsync-over-SSH destination. Leave blank to use
# the running user's default ~/.ssh keys / agent. Mount the key into the
# container and point this at it for unattended rsync uploads.
DRIFT_SSH_KEY_PATH=
